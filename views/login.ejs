<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Login — Chat App</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Segoe UI', sans-serif;
      background: #f0f2f5;
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
    }
    .card {
      background: #fff;
      padding: 2rem;
      border-radius: 12px;
      box-shadow: 0 2px 16px rgba(0,0,0,0.1);
      width: 100%;
      max-width: 400px;
    }
    h2 { text-align: center; margin-bottom: 1.5rem; color: #1a1a2e; }
    .form-group { margin-bottom: 1rem; }
    label { display: block; margin-bottom: 0.4rem; font-size: 0.9rem; color: #555; }
    input {
      width: 100%;
      padding: 0.75rem 1rem;
      border: 1px solid #ddd;
      border-radius: 8px;
      font-size: 1rem;
      outline: none;
      transition: border 0.2s;
    }
    input:focus { border-color: #6c63ff; }
    button {
      width: 100%;
      padding: 0.85rem;
      background: #6c63ff;
      color: #fff;
      border: none;
      border-radius: 8px;
      font-size: 1rem;
      cursor: pointer;
      margin-top: 0.5rem;
      transition: background 0.2s;
    }
    button:hover { background: #5a52d5; }
    .error {
      color: #e53e3e;
      font-size: 0.85rem;
      margin-top: 0.75rem;
      text-align: center;
      display: none;
    }
    .footer {
      text-align: center;
      margin-top: 1.2rem;
      font-size: 0.9rem;
      color: #777;
    }
    .footer a { color: #6c63ff; text-decoration: none; }
  </style>
</head>
<body>
  <div class="card">
    <h2>💬 Chat App</h2>
    <div class="form-group">
      <label>Email</label>
      <input type="email" id="email" placeholder="your@email.com" />
    </div>
    <div class="form-group">
      <label>Password</label>
      <input type="password" id="password" placeholder="••••••••" />
    </div>
    <button id="loginBtn">Login</button>
    <p class="error" id="errorMsg"></p>
    <div class="footer">
      Don't have an account? <a href="/register">Register</a>
    </div>
  </div>

  <script>
    // ── Phase 1 Test: Login করে accessToken পাও ──────────────
    // accessToken → localStorage-এ save → /chat page-এ Socket connect-এ দেবো
    document.getElementById('loginBtn').addEventListener('click', async () => {
      const email    = document.getElementById('email').value.trim();
      const password = document.getElementById('password').value.trim();
      const errorEl  = document.getElementById('errorMsg');

      if (!email || !password) {
        errorEl.style.display = 'block';
        errorEl.textContent = 'Email and password are required.';
        return;
      }

      try {
        const res = await fetch('/api/v1/auth/login', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify({ email, password }),
        });

        const data = await res.json();

        if (!data.success) {
          errorEl.style.display = 'block';
          errorEl.textContent = data.message || 'Login failed.';
          return;
        }

        // accessToken localStorage-এ save করো
        // Phase 1 test-এ: chat.ejs-এ এটা socket auth-এ পাঠাবে
        localStorage.setItem('accessToken', data.data.accessToken);
        localStorage.setItem('user', JSON.stringify(data.data.user));

        // Chat page-এ redirect করো
        window.location.href = '/chat';
      } catch (err) {
        errorEl.style.display = 'block';
        errorEl.textContent = 'Server error. Try again.';
      }
    });
  </script>
</body>
</html>
