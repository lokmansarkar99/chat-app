<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ChatApp</title>
    <script src="/socket.io/socket.io.js"></script>
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      :root {
        --bg-primary: #1a1a2e;
        --bg-secondary: #16213e;
        --bg-tertiary: #0f3460;
        --accent: #6c63ff;
        --accent-dark: #5a52d5;
        --text-primary: #fff;
        --text-secondary: #a0aec0;
        --text-muted: #4a5568;
        --green: #48bb78;
        --red: #fc8181;
        --border: rgba(255, 255, 255, 0.07);
      }
      body {
        font-family: "Segoe UI", sans-serif;
        background: var(--bg-primary);
        color: var(--text-primary);
        height: 100vh; display: flex; overflow: hidden;
      }

      /* ════════ SIDEBAR ════════ */
      .sidebar {
        width: 320px; min-width: 320px;
        background: var(--bg-secondary);
        border-right: 1px solid var(--border);
        display: flex; flex-direction: column; height: 100vh;
      }
      .sidebar-header {
        padding: 1rem 1.25rem;
        border-bottom: 1px solid var(--border);
        display: flex; align-items: center; gap: 0.65rem;
        background: var(--bg-tertiary);
      }
      .my-avatar {
        width: 40px; height: 40px; border-radius: 50%;
        background: var(--accent);
        display: flex; align-items: center; justify-content: center;
        font-weight: 700; font-size: 1rem;
        flex-shrink: 0; position: relative;
      }
      .my-avatar .status-dot {
        position: absolute; bottom: 1px; right: 1px;
        width: 10px; height: 10px; border-radius: 50%;
        background: var(--green); border: 2px solid var(--bg-tertiary);
      }
      .my-info { flex: 1; min-width: 0; }
      .my-name {
        font-weight: 600; font-size: 0.88rem;
        white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
      }
      .my-online { font-size: 0.7rem; color: var(--green); }

      .new-chat-btn {
        background: rgba(108,99,255,0.15);
        border: 1px solid rgba(108,99,255,0.3);
        color: var(--accent); cursor: pointer; font-size: 1rem;
        width: 34px; height: 34px; border-radius: 8px;
        display: flex; align-items: center; justify-content: center;
        transition: all 0.2s; flex-shrink: 0;
      }
      .new-chat-btn:hover { background: rgba(108,99,255,0.3); transform: scale(1.05); }

      .logout-btn {
        background: none; border: none; color: var(--red);
        cursor: pointer; font-size: 0.72rem;
        padding: 0.25rem 0.45rem; border-radius: 6px; transition: background 0.2s;
      }
      .logout-btn:hover { background: rgba(252,129,129,0.1); }

      .search-box { padding: 0.75rem 1rem; border-bottom: 1px solid var(--border); }
      .search-input {
        width: 100%; padding: 0.6rem 1rem;
        background: rgba(255,255,255,0.05);
        border: 1px solid var(--border); border-radius: 20px;
        color: var(--text-primary); font-size: 0.85rem;
        outline: none; transition: all 0.2s;
      }
      .search-input:focus { border-color: var(--accent); }
      .search-input::placeholder { color: var(--text-muted); }

      .conv-list { flex: 1; overflow-y: auto; padding: 0.5rem 0; }
      .conv-list::-webkit-scrollbar { width: 4px; }
      .conv-list::-webkit-scrollbar-thumb { background: var(--text-muted); border-radius: 2px; }

      .conv-item {
        display: flex; align-items: center; gap: 0.75rem;
        padding: 0.75rem 1.25rem; cursor: pointer;
        transition: background 0.15s;
        border-bottom: 1px solid var(--border); position: relative;
      }
      .conv-item:hover { background: rgba(108,99,255,0.08); }
      .conv-item.active { background: rgba(108,99,255,0.15); border-left: 3px solid var(--accent); }
      .conv-avatar {
        width: 46px; height: 46px; border-radius: 50%;
        background: var(--bg-tertiary);
        display: flex; align-items: center; justify-content: center;
        font-weight: 700; font-size: 1.1rem;
        flex-shrink: 0; position: relative;
      }
      .conv-avatar .dot {
        position: absolute; bottom: 2px; right: 2px;
        width: 11px; height: 11px; border-radius: 50%;
        background: var(--green); border: 2px solid var(--bg-secondary); display: none;
      }
      .conv-avatar .dot.on { display: block; }
      .conv-body { flex: 1; min-width: 0; }
      .conv-name {
        font-weight: 600; font-size: 0.9rem;
        white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
      }
      .conv-preview {
        font-size: 0.78rem; color: var(--text-secondary);
        white-space: nowrap; overflow: hidden; text-overflow: ellipsis; margin-top: 0.2rem;
      }
      .conv-meta { display: flex; flex-direction: column; align-items: flex-end; gap: 0.3rem; flex-shrink: 0; }
      .conv-time { font-size: 0.7rem; color: var(--text-muted); }
      .badge {
        background: var(--accent); color: #fff;
        font-size: 0.65rem; font-weight: 700;
        padding: 0.15rem 0.45rem; border-radius: 10px;
        min-width: 18px; text-align: center; display: none;
      }
      .conv-empty { text-align: center; color: var(--text-muted); padding: 3rem 1rem; font-size: 0.88rem; }

      /* ════════ NEW CHAT MODAL ════════ */
      .modal-overlay {
        position: fixed; inset: 0;
        background: rgba(0,0,0,0.65);
        backdrop-filter: blur(4px);
        z-index: 200; display: none;
      }
      .modal-overlay.show { display: block; }

      .user-modal {
        position: fixed; top: 50%; left: 50%;
        transform: translate(-50%, -52%) scale(0.95);
        background: var(--bg-secondary);
        border: 1px solid rgba(108,99,255,0.25);
        border-radius: 16px;
        width: 92%; max-width: 440px; max-height: 82vh;
        display: flex; flex-direction: column;
        z-index: 201;
        box-shadow: 0 24px 64px rgba(0,0,0,0.6);
        opacity: 0; pointer-events: none;
        transition: all 0.22s cubic-bezier(0.34,1.56,0.64,1);
      }
      .user-modal.show { opacity: 1; pointer-events: all; transform: translate(-50%,-50%) scale(1); }

      .modal-header {
        display: flex; align-items: center; justify-content: space-between;
        padding: 1.1rem 1.25rem 0.8rem;
        border-bottom: 1px solid var(--border);
        flex-shrink: 0;
      }
      .modal-header h3 { font-size: 0.95rem; font-weight: 600; }
      .modal-close {
        background: none; border: none; color: var(--text-secondary);
        cursor: pointer; font-size: 1rem;
        width: 28px; height: 28px; border-radius: 6px;
        transition: all 0.2s; display: flex; align-items: center; justify-content: center;
      }
      .modal-close:hover { color: var(--red); background: rgba(252,129,129,0.1); }

      .modal-search { padding: 0.85rem 1rem 0.5rem; flex-shrink: 0; }
      .modal-search input {
        width: 100%; padding: 0.65rem 1rem;
        background: rgba(255,255,255,0.05);
        border: 1px solid var(--border); border-radius: 10px;
        color: var(--text-primary); font-size: 0.88rem;
        outline: none; transition: border 0.2s;
      }
      .modal-search input:focus { border-color: var(--accent); background: rgba(108,99,255,0.05); }
      .modal-search input::placeholder { color: var(--text-muted); }

      .modal-user-list {
        flex: 1; overflow-y: auto;
        padding: 0.5rem 0.75rem 0.85rem;
        display: flex; flex-direction: column; gap: 0.35rem;
      }
      .modal-user-list::-webkit-scrollbar { width: 4px; }
      .modal-user-list::-webkit-scrollbar-thumb { background: var(--text-muted); border-radius: 2px; }

      .modal-hint {
        text-align: center; color: var(--text-muted);
        font-size: 0.83rem; padding: 2rem 0;
        display: flex; align-items: center; justify-content: center; gap: 0.5rem;
      }

      .modal-user-item {
        display: flex; align-items: center; gap: 0.75rem;
        padding: 0.7rem 0.75rem; border-radius: 10px;
        cursor: pointer; transition: background 0.15s;
        border: 1px solid transparent;
      }
      .modal-user-item:hover { background: rgba(108,99,255,0.1); border-color: rgba(108,99,255,0.2); }
      .modal-user-item.starting { opacity: 0.5; pointer-events: none; }

      .mu-avatar {
        width: 44px; height: 44px; border-radius: 50%;
        background: var(--bg-tertiary); overflow: hidden;
        display: flex; align-items: center; justify-content: center;
        font-weight: 700; font-size: 1.05rem;
        flex-shrink: 0; position: relative;
      }
      .mu-avatar img { width: 100%; height: 100%; object-fit: cover; }
      .mu-avatar .dot {
        position: absolute; bottom: 1px; right: 1px;
        width: 10px; height: 10px; border-radius: 50%;
        background: var(--green); border: 2px solid var(--bg-secondary); display: none;
      }
      .mu-avatar .dot.on { display: block; }
      .mu-info { flex: 1; min-width: 0; }
      .mu-name { font-weight: 600; font-size: 0.88rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
      .mu-email { font-size: 0.73rem; color: var(--text-muted); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; margin-top: 0.1rem; }
      .mu-status { font-size: 0.7rem; margin-top: 0.2rem; }
      .mu-status.online { color: var(--green); }
      .mu-status.offline { color: var(--text-muted); }
      .mu-badge {
        font-size: 0.72rem; font-weight: 600;
        padding: 0.22rem 0.65rem; border-radius: 6px; flex-shrink: 0;
      }
      .mu-badge.new-chat  { color: var(--accent); background: rgba(108,99,255,0.12); }
      .mu-badge.open-chat { color: var(--green);  background: rgba(72,187,120,0.12); }
      .mu-badge.loading   { color: var(--text-muted); background: rgba(255,255,255,0.05); }

      /* ════════ CHAT AREA ════════ */
      .chat-area { flex: 1; display: flex; flex-direction: column; height: 100vh; overflow: hidden; }
      .chat-placeholder {
        flex: 1; display: flex; flex-direction: column;
        align-items: center; justify-content: center; color: var(--text-muted);
      }
      .ph-icon { font-size: 3.5rem; margin-bottom: 1rem; opacity: 0.35; }
      .ph-sub { font-size: 0.8rem; margin-top: 0.4rem; color: var(--text-muted); }

      .chat-header {
        padding: 0.9rem 1.25rem; background: var(--bg-secondary);
        border-bottom: 1px solid var(--border);
        display: none; align-items: center; gap: 0.75rem; flex-shrink: 0;
      }
      .chat-header.show { display: flex; }
      .peer-avatar {
        width: 40px; height: 40px; border-radius: 50%;
        background: var(--bg-tertiary); overflow: hidden;
        display: flex; align-items: center; justify-content: center;
        font-weight: 700; font-size: 1rem;
        flex-shrink: 0; position: relative;
      }
      .peer-avatar .dot {
        position: absolute; bottom: 1px; right: 1px;
        width: 10px; height: 10px; border-radius: 50%;
        background: var(--green); border: 2px solid var(--bg-secondary); display: none;
      }
      .peer-avatar .dot.on { display: block; }
      .peer-info { flex: 1; }
      .peer-name { font-weight: 600; font-size: 0.95rem; }
      .peer-status { font-size: 0.75rem; color: var(--text-secondary); min-height: 16px; transition: color 0.2s; }
      .peer-status.online { color: var(--green); }

      .messages-wrap {
        flex: 1; overflow-y: auto; padding: 1.25rem;
        display: none; flex-direction: column; gap: 0.5rem;
      }
      .messages-wrap.show { display: flex; }
      .messages-wrap::-webkit-scrollbar { width: 4px; }
      .messages-wrap::-webkit-scrollbar-thumb { background: var(--text-muted); border-radius: 2px; }

      .msg-row { display: flex; align-items: flex-end; gap: 0.5rem; }
      .msg-row.sent { flex-direction: row-reverse; }
      .msg-bubble {
        max-width: 65%; padding: 0.65rem 0.9rem;
        border-radius: 16px; font-size: 0.9rem; line-height: 1.5; word-break: break-word;
      }
      .msg-row.sent .msg-bubble {
        background: linear-gradient(135deg, var(--accent), var(--accent-dark));
        color: #fff; border-bottom-right-radius: 4px;
      }
      .msg-row.recv .msg-bubble { background: #1e3a5f; color: var(--text-primary); border-bottom-left-radius: 4px; }
      .msg-img { max-width: 200px; border-radius: 10px; margin-bottom: 0.35rem; display: block; cursor: pointer; }
      .msg-img:hover { opacity: 0.9; }
      .msg-footer { display: flex; align-items: center; gap: 0.3rem; margin-top: 0.3rem; justify-content: flex-end; }
      .msg-time { font-size: 0.65rem; opacity: 0.65; }

      .st-sending   { color: rgba(255,255,255,0.4); font-size: 0.7rem; }
      .st-delivered { color: rgba(255,255,255,0.75); font-size: 0.7rem; }
      .st-read      { color: #63b3ed; font-size: 0.7rem; }

      .date-sep { text-align: center; margin: 0.75rem 0; }
      .date-sep span {
        background: rgba(255,255,255,0.06); color: var(--text-muted);
        font-size: 0.72rem; padding: 0.25rem 0.75rem; border-radius: 10px;
      }

      .typing-row { display: none; align-items: center; gap: 0.4rem; padding: 0.25rem 0; color: var(--text-secondary); font-size: 0.8rem; }
      .typing-row.show { display: flex; }
      .dots span {
        display: inline-block; width: 6px; height: 6px;
        background: var(--text-muted); border-radius: 50%;
        animation: blink 1.4s infinite; margin: 0 1px;
      }
      .dots span:nth-child(2) { animation-delay: 0.2s; }
      .dots span:nth-child(3) { animation-delay: 0.4s; }
      @keyframes blink { 0%,80%,100%{opacity:0.2} 40%{opacity:1} }

      .input-bar {
        padding: 0.85rem 1.25rem; background: var(--bg-secondary);
        border-top: 1px solid var(--border);
        display: none; gap: 0.75rem; align-items: flex-end; flex-shrink: 0;
      }
      .input-bar.show { display: flex; }
      .attach-btn {
        background: none; border: none; color: var(--text-secondary);
        cursor: pointer; font-size: 1.3rem; padding: 0.3rem;
        border-radius: 8px; transition: color 0.2s; flex-shrink: 0; align-self: center;
      }
      .attach-btn:hover { color: var(--accent); }
      .input-wrap { flex: 1; display: flex; flex-direction: column; gap: 0.35rem; }
      .attach-preview {
        background: rgba(108,99,255,0.1); border: 1px solid rgba(108,99,255,0.3);
        border-radius: 8px; padding: 0.35rem 0.75rem;
        font-size: 0.78rem; color: var(--accent);
        display: none; align-items: center; gap: 0.5rem;
      }
      .attach-preview.show { display: flex; }
      .rm-attach { cursor: pointer; color: var(--red); font-size: 1rem; }
      .msg-input {
        width: 100%; padding: 0.7rem 1rem;
        background: rgba(255,255,255,0.05);
        border: 1px solid var(--border); border-radius: 22px;
        color: var(--text-primary); font-size: 0.9rem;
        outline: none; resize: none; max-height: 120px;
        overflow-y: auto; line-height: 1.5;
        transition: border 0.2s; font-family: inherit;
      }
      .msg-input:focus { border-color: var(--accent); background: rgba(108,99,255,0.06); }
      .msg-input::placeholder { color: var(--text-muted); }
      .send-btn {
        width: 44px; height: 44px; border-radius: 50%;
        background: linear-gradient(135deg, var(--accent), var(--accent-dark));
        border: none; color: #fff; cursor: pointer; font-size: 1.1rem;
        display: flex; align-items: center; justify-content: center;
        transition: all 0.2s; flex-shrink: 0; align-self: flex-end;
      }
      .send-btn:hover { transform: scale(1.08); box-shadow: 0 4px 15px rgba(108,99,255,0.4); }

      .toast {
        position: fixed; bottom: 2rem; right: 2rem;
        background: var(--bg-tertiary); color: #fff;
        padding: 0.75rem 1.25rem; border-radius: 10px;
        font-size: 0.85rem; box-shadow: 0 8px 25px rgba(0,0,0,0.4);
        transform: translateY(100px); opacity: 0; transition: all 0.3s; z-index: 9999;
      }
      .toast.show { transform: translateY(0); opacity: 1; }
      .loading-msg {
        display: flex; align-items: center; justify-content: center;
        padding: 2rem; color: var(--text-muted); font-size: 0.85rem; gap: 0.75rem;
      }
      .spin {
        width: 18px; height: 18px;
        border: 2px solid var(--text-muted); border-top-color: var(--accent);
        border-radius: 50%; animation: spin 0.7s linear infinite; display: inline-block;
      }
      @keyframes spin { to { transform: rotate(360deg); } }
    </style>
  </head>
  <body>

    <!-- ═══════════════ SIDEBAR ═══════════════ -->
    <div class="sidebar">
      <div class="sidebar-header">
        <div class="my-avatar" id="myAvatar">?<div class="status-dot"></div></div>
        <div class="my-info">
          <div class="my-name"  id="myName">—</div>
          <div class="my-online">● Online</div>
        </div>
        <button class="new-chat-btn" onclick="openUserModal()" title="New Conversation">✏️</button>
        <button class="logout-btn"   onclick="logout()">Sign out</button>
      </div>

      <div class="search-box">
        <input class="search-input" id="searchInput" type="text" placeholder="🔍 Search conversations..."/>
      </div>

      <div class="conv-list" id="convList">
        <div class="loading-msg"><div class="spin"></div> Loading...</div>
      </div>
    </div>

    <!-- ═══════════════ NEW CHAT MODAL ═══════════════ -->
    <div class="modal-overlay" id="modalOverlay" onclick="closeUserModal()"></div>
    <div class="user-modal" id="userModal">
      <div class="modal-header">
        <h3>💬 New Conversation</h3>
        <button class="modal-close" onclick="closeUserModal()">✕</button>
      </div>
      <div class="modal-search">
        <input
          type="text"
          id="userSearchInput"
          placeholder="🔍 Search by name or email..."
          autocomplete="off"
          oninput="searchUsers(this.value)"
        />
      </div>
      <div class="modal-user-list" id="modalUserList">
        <div class="modal-hint">✏️ Type a name or email to search</div>
      </div>
    </div>

    <!-- ═══════════════ CHAT AREA ═══════════════ -->
    <div class="chat-area">
      <div class="chat-placeholder" id="chatPlaceholder">
        <div class="ph-icon">💬</div>
        <p>Select a conversation to start chatting</p>
        <p class="ph-sub">or press ✏️ to start a new one</p>
      </div>

      <div class="chat-header" id="chatHeader">
        <div class="peer-avatar" id="peerAvatar">
          ?<div class="dot" id="peerDot"></div>
        </div>
        <div class="peer-info">
          <div class="peer-name"   id="peerName">—</div>
          <div class="peer-status" id="peerStatus">—</div>
        </div>
      </div>

      <div class="messages-wrap" id="msgsWrap">
        <div class="typing-row" id="typingRow">
          <div class="dots"><span></span><span></span><span></span></div>
          <span id="typingText"></span>
        </div>
      </div>

      <div class="input-bar" id="inputBar">
        <button class="attach-btn" onclick="document.getElementById('fileInput').click()">📎</button>
        <input type="file" id="fileInput" accept="image/*,video/mp4,audio/mpeg,application/pdf" style="display:none"/>
        <div class="input-wrap">
          <div class="attach-preview" id="attachPreview">
            <span id="attachName"></span>
            <span class="rm-attach" onclick="clearAttach()">✕</span>
          </div>
          <textarea class="msg-input" id="msgInput" rows="1" placeholder="Type a message..."></textarea>
        </div>
        <button class="send-btn" id="sendBtn">➤</button>
      </div>
    </div>

    <div class="toast" id="toast"></div>

    <script>
      // ═══════════════════════════════════════════════════
      // AUTH GUARD
      // ═══════════════════════════════════════════════════
      const token = localStorage.getItem("accessToken");
      const me    = JSON.parse(localStorage.getItem("user") || "null");
      if (!token || !me) window.location.href = "/login";

      // ═══════════════════════════════════════════════════
      // STATE
      // ═══════════════════════════════════════════════════
      const API         = "/api/v1";
      let activeConv    = null;       // { id, peerId, peerName }
      let conversations = [];         // ✅ shared — sidebar + modal দুটোই use করে
      let onlineIds     = new Set();
      let pendingFile   = null;
      let typingTmr     = null;
      let userSearchTmr = null;
      const tickMap     = {};         // tempId → <span> DOM ref

      // ═══════════════════════════════════════════════════
      // MY INFO
      // ═══════════════════════════════════════════════════
      document.getElementById("myAvatar").childNodes[0].textContent =
        (me.name || "U").charAt(0).toUpperCase();
      document.getElementById("myName").textContent = me.name || "—";

      // ═══════════════════════════════════════════════════
      // SOCKET
      // ═══════════════════════════════════════════════════
      const socket = io({ auth: { token }, transports: ["websocket"] });

      socket.on("connect", loadConversations);

      socket.on("connect_error", (err) => {
        showToast("❌ " + err.message);
        if (/expired|Invalid|Authentication/i.test(err.message)) {
          setTimeout(() => { localStorage.clear(); location.href = "/login"; }, 2000);
        }
      });

      // ═══════════════════════════════════════════════════
      // ONLINE / OFFLINE
      // ═══════════════════════════════════════════════════
      socket.on("online:users-list", (ids) => {
        onlineIds = new Set(ids);
        refreshDots();
        refreshPeerStatus();
      });

      socket.on("user:online", ({ userId }) => {
        onlineIds.add(userId);
        refreshDots();
        refreshPeerStatus();
        if (activeConv && userId === activeConv.peerId) {
          document.querySelectorAll(".st-sending").forEach((el) => {
            el.textContent = "✓✓"; el.className = "st-delivered";
          });
          showToast(`${activeConv.peerName} is now online 🟢`);
        }
      });

      socket.on("user:offline", ({ userId, lastSeen }) => {
        onlineIds.delete(userId);
        refreshDots();
        if (activeConv && userId === activeConv.peerId)
          setPeerStatus(`Last seen ${fmtTime(lastSeen)}`, false);
      });

      // ═══════════════════════════════════════════════════
      // MESSAGE EVENTS
      // ═══════════════════════════════════════════════════
      socket.on("message:new", (msg) => {
        const sid    = msg.sender?._id || msg.sender;
        const isMine = sid === me._id;
        updatePreview(msg.conversation, msg.text, msg.attachment, msg.createdAt);
        if (activeConv && msg.conversation === activeConv.id) {
          if (!isMine) { appendMsg(msg, false); scrollBottom(); doMarkRead(activeConv.id, sid); }
        } else if (!isMine) { incrBadge(msg.conversation); }
      });

      socket.on("message:saved", ({ tempId }) => {
        const el = tickMap[tempId];
        if (el) { el.textContent = "✓"; el.className = "st-sending"; }
        delete tickMap[tempId];
      });

      socket.on("message:delivered", ({ tempId }) => {
        const el = tickMap[tempId];
        if (el) { el.textContent = "✓✓"; el.className = "st-delivered"; }
        delete tickMap[tempId];
      });

      socket.on("message:read-receipt", ({ conversationId }) => {
        if (!activeConv || conversationId !== activeConv.id) return;
        document.querySelectorAll(".st-sending, .st-delivered").forEach((el) => {
          el.textContent = "✓✓"; el.className = "st-read";
        });
      });

      socket.on("typing:indicator", ({ userId, userName, conversationId, isTyping }) => {
        if (!activeConv || conversationId !== activeConv.id || userId === me._id) return;
        const row = document.getElementById("typingRow");
        if (isTyping) {
          document.getElementById("typingText").textContent = `${userName} is typing...`;
          row.classList.add("show"); scrollBottom();
        } else { row.classList.remove("show"); }
      });

      // ═══════════════════════════════════════════════════
      // LOAD CONVERSATIONS (sidebar)
      // ═══════════════════════════════════════════════════
      async function loadConversations() {
        try {
          const data    = await get(`${API}/conversation/my`);
          conversations = data.data || [];
          renderSidebar(conversations);
        } catch {
          document.getElementById("convList").innerHTML =
            '<div class="conv-empty">❌ Failed to load</div>';
        }
      }

      function renderSidebar(list) {
        const el = document.getElementById("convList");
        if (!list.length) {
          el.innerHTML = `<div class="conv-empty">
            💬 No conversations yet<br/>
            <small style="font-size:.75rem;color:var(--text-muted)">Press ✏️ to start one</small>
          </div>`;
          return;
        }
        el.innerHTML = list.map((c) => {
          const peer     = getPeer(c.participants);
          const peerId   = peer._id  || peer;
          const peerName = peer.name || "?";
          const isOn     = onlineIds.has(peerId);
          const preview  = c.lastMessage?.text
            || (c.lastMessage?.attachment ? "📎 Attachment" : "No messages");
          const t        = c.lastMessageAt ? fmtTime(c.lastMessageAt) : "";
          const active   = activeConv?.id === c._id ? "active" : "";
          return `
            <div class="conv-item ${active}" id="ci-${c._id}"
                 onclick="openConv('${c._id}','${peerId}','${esc(peerName)}')">
              <div class="conv-avatar">
                ${esc(peerName).charAt(0).toUpperCase()}
                <div class="dot ${isOn ? "on" : ""}" id="dot-${peerId}"></div>
              </div>
              <div class="conv-body">
                <div class="conv-name">${esc(peerName)}</div>
                <div class="conv-preview" id="pv-${c._id}">${esc(preview)}</div>
              </div>
              <div class="conv-meta">
                <span class="conv-time" id="pt-${c._id}">${t}</span>
                <span class="badge"     id="bd-${c._id}">0</span>
              </div>
            </div>`;
        }).join("");
      }

      // ═══════════════════════════════════════════════════
      // MODAL — Open / Close
      // ═══════════════════════════════════════════════════
      function openUserModal() {
        document.getElementById("modalOverlay").classList.add("show");
        document.getElementById("userModal").classList.add("show");
        setTimeout(() => document.getElementById("userSearchInput").focus(), 150);
      }

      function closeUserModal() {
        document.getElementById("modalOverlay").classList.remove("show");
        document.getElementById("userModal").classList.remove("show");
        document.getElementById("userSearchInput").value = "";
        document.getElementById("modalUserList").innerHTML =
          '<div class="modal-hint">✏️ Type a name or email to search</div>';
        clearTimeout(userSearchTmr);
      }

      document.addEventListener("keydown", (e) => { if (e.key === "Escape") closeUserModal(); });

      // ═══════════════════════════════════════════════════
      // MODAL — Search Users
      // ✅ Endpoint: GET /api/v1/user/users/chats?search=xxx&role=USER
      // ✅ Response: data.data.users → array
      // ═══════════════════════════════════════════════════
      function searchUsers(query) {
        clearTimeout(userSearchTmr);
        const listEl = document.getElementById("modalUserList");

        if (!query.trim()) {
          listEl.innerHTML = '<div class="modal-hint">✏️ Type a name or email to search</div>';
          return;
        }

        // Show loading spinner
        listEl.innerHTML = '<div class="modal-hint"><div class="spin"></div></div>';

        // Debounce 400ms — avoid too many requests while typing
        userSearchTmr = setTimeout(async () => {
          try {
            // ✅ YOUR exact endpoint
            const url  = `${API}/user/users/chats?role=USER&search=${encodeURIComponent(query.trim())}`;
            const data = await get(url);

            if (!data.success) {
              listEl.innerHTML = `<div class="modal-hint">❌ ${data.message || "API error"}</div>`;
              return;
            }

            // ✅ YOUR response shape: data.data.users
            const users = (data.data?.users || []).filter((u) => u._id !== me._id);

            if (!users.length) {
              listEl.innerHTML = '<div class="modal-hint">😕 No users found</div>';
              return;
            }

            renderModalUsers(users);

          } catch (err) {
            console.error("[searchUsers] error:", err);
            listEl.innerHTML = '<div class="modal-hint">❌ Search failed. Check console.</div>';
          }
        }, 400);
      }

      // ═══════════════════════════════════════════════════
      // MODAL — Render User Results
      // ═══════════════════════════════════════════════════
      function renderModalUsers(users) {
        const listEl = document.getElementById("modalUserList");

        listEl.innerHTML = users.map((user) => {
          const initial  = (user.name || "?").charAt(0).toUpperCase();
          const isOn     = onlineIds.has(user._id);

          // "Open" if conversation already exists, else "Chat"
          const existing   = conversations.find((c) =>
            c.participants.some((p) => (p._id || p) === user._id)
          );
          const badgeLabel = existing ? "Open" : "Chat";
          const badgeCls   = existing ? "mu-badge open-chat" : "mu-badge new-chat";

          // Profile image or initial
          const avatarInner = (user.profileImage && user.profileImage.trim())
            ? `<img src="${user.profileImage}" alt="${esc(user.name)}"
                    onerror="this.style.display='none';this.nextSibling.style.display='flex'"/>
               <span style="display:none;width:100%;height:100%;align-items:center;justify-content:center">${initial}</span>`
            : initial;

          return `
            <div class="modal-user-item" id="mui-${user._id}"
                 onclick="startConversation('${user._id}', '${esc(user.name)}')">
              <div class="mu-avatar">
                ${avatarInner}
                <div class="dot ${isOn ? "on" : ""}"></div>
              </div>
              <div class="mu-info">
                <div class="mu-name">${esc(user.name)}</div>
                <div class="mu-email">${esc(user.email || "")}</div>
                <div class="mu-status ${isOn ? "online" : "offline"}">
                  ${isOn ? "● Online" : "○ Offline"}
                </div>
              </div>
              <span class="${badgeCls}" id="mub-${user._id}">${badgeLabel}</span>
            </div>`;
        }).join("");
      }

      // ═══════════════════════════════════════════════════
      // MODAL — Start or Open Conversation
      // POST /api/v1/conversation/start { receiverId }
      // ═══════════════════════════════════════════════════
      async function startConversation(receiverId, receiverName) {
        const itemEl  = document.getElementById(`mui-${receiverId}`);
        const badgeEl = document.getElementById(`mub-${receiverId}`);

        if (itemEl)  itemEl.classList.add("starting");
        if (badgeEl) { badgeEl.textContent = "..."; badgeEl.className = "mu-badge loading"; }

        try {
          const res  = await fetch(`${API}/conversation/start`, {
            method:  "POST",
            headers: {
              "Content-Type": "application/json",
              Authorization:  `Bearer ${token}`,
            },
            body: JSON.stringify({ receiverId }),
          });
          const data = await res.json();

          if (!data.success) {
            showToast("❌ " + (data.message || "Failed"));
            if (badgeEl) { badgeEl.textContent = "Chat"; badgeEl.className = "mu-badge new-chat"; }
            return;
          }

          const conv = data.data;

          // ── Sidebar-এ add করো if new ───────────────────
          const exists = conversations.find((c) => c._id === conv._id);
          if (!exists) {
            conversations.unshift(conv);
            renderSidebar(conversations);
          }

          // ── Modal বন্ধ + conversation open ─────────────
          closeUserModal();

          const peer  = getPeer(conv.participants);
          const pId   = peer._id  || peer;
          const pName = peer.name || receiverName;
          await openConv(conv._id, pId, pName);

          showToast(`💬 Chat with ${pName} opened!`);

        } catch {
          showToast("❌ Network error. Try again.");
          if (badgeEl) { badgeEl.textContent = "Chat"; badgeEl.className = "mu-badge new-chat"; }
        } finally {
          if (itemEl) itemEl.classList.remove("starting");
        }
      }

      // ═══════════════════════════════════════════════════
      // OPEN CONVERSATION
      // ═══════════════════════════════════════════════════
      async function openConv(convId, peerId, peerName) {
        if (activeConv) socket.emit("leave:conversation", activeConv.id);
        activeConv = { id: convId, peerId, peerName };

        // Sidebar highlight
        document.querySelectorAll(".conv-item").forEach((e) => e.classList.remove("active"));
        document.getElementById(`ci-${convId}`)?.classList.add("active");
        hideBadge(convId);

        // Show panels
        document.getElementById("chatPlaceholder").style.display = "none";
        document.getElementById("chatHeader").classList.add("show");
        document.getElementById("msgsWrap").classList.add("show");
        document.getElementById("inputBar").classList.add("show");

        // Peer header
        const avatarEl = document.getElementById("peerAvatar");
        avatarEl.childNodes[0].textContent = peerName.charAt(0).toUpperCase();
        document.getElementById("peerName").textContent = peerName;
        refreshPeerStatus();

        // Load messages
        const wrap    = document.getElementById("msgsWrap");
        const typingEl= document.getElementById("typingRow");
        wrap.innerHTML = `<div class="loading-msg"><div class="spin"></div> Loading...</div>`;
        wrap.appendChild(typingEl);

        try {
          const data = await get(`${API}/message/${convId}?limit=50`);
          wrap.innerHTML = "";
          wrap.appendChild(typingEl);

          // ✅ flexible shape: data.data.messages or data.data
          const msgs = data.data?.messages || (Array.isArray(data.data) ? data.data : []);

          if (msgs.length) {
            let lastDate = "";
            msgs.forEach((m) => {
              const d = new Date(m.createdAt).toLocaleDateString();
              if (d !== lastDate) { appendDateSep(d); lastDate = d; }
              appendMsg(m, false);
            });
          } else {
            const empty = document.createElement("div");
            empty.style.cssText = "text-align:center;color:var(--text-muted);padding:2rem;font-size:.85rem";
            empty.textContent   = `👋 Say hello to ${peerName}`;
            wrap.insertBefore(empty, typingEl);
          }
          scrollBottom();
        } catch { showToast("Failed to load messages"); }

        socket.emit("join:conversation", convId);
        doMarkRead(convId, peerId);
        document.getElementById("msgInput").focus();
      }

      // ═══════════════════════════════════════════════════
      // SEND MESSAGE
      // ═══════════════════════════════════════════════════
      document.getElementById("sendBtn").addEventListener("click", sendMsg);
      document.getElementById("msgInput").addEventListener("keydown", (e) => {
        if (e.key === "Enter" && !e.shiftKey) { e.preventDefault(); sendMsg(); }
      });

      async function sendMsg() {
        if (!activeConv) return;
        const input = document.getElementById("msgInput");
        const text  = input.value.trim();
        if (!text && !pendingFile) return;

        const tempId = "tmp_" + Date.now();

        appendMsg({
          _id:        tempId,
          sender:     { _id: me._id, name: me.name },
          text,
          attachment: pendingFile ? URL.createObjectURL(pendingFile) : null,
          isRead:     false,
          createdAt:  new Date(),
        }, true, tempId);
        scrollBottom();

        input.value = "";
        autoResize(input);

        if (pendingFile) {
          const fd = new FormData();
          fd.append("conversationId", activeConv.id);
          fd.append("tempId",         tempId);
          if (text) fd.append("text", text);
          fd.append("attachment", pendingFile);
          clearAttach();

          try {
            const res  = await fetch(`${API}/message`, {
              method: "POST",
              headers: { Authorization: `Bearer ${token}` },
              body: fd,
            });
            const data = await res.json();
            if (!data.success) {
              showToast("❌ " + data.message);
              const el = tickMap[tempId];
              if (el) { el.textContent = "!"; el.style.color = "var(--red)"; }
            }
          } catch {
            showToast("❌ Send failed. Check connection.");
            const el = tickMap[tempId];
            if (el) { el.textContent = "!"; el.style.color = "var(--red)"; }
          }

        } else {
          socket.emit("message:send", {
            conversationId: activeConv.id,
            receiverId:     activeConv.peerId,
            text,
            tempId,
          });
          socket.emit("typing:stop", activeConv.id);
        }
      }

      // ═══════════════════════════════════════════════════
      // APPEND MESSAGE BUBBLE
      // ═══════════════════════════════════════════════════
      function appendMsg(msg, isOptimistic, tempId = null) {
        const wrap    = document.getElementById("msgsWrap");
        const typingEl= document.getElementById("typingRow");
        const sid     = msg.sender?._id || msg.sender;
        const isSent  = sid === me._id;
        const t       = fmtTime(msg.createdAt);

        const row     = document.createElement("div");
        row.className = `msg-row ${isSent ? "sent" : "recv"}`;

        // Attachment
        let mediaHTML = "";
        if (msg.attachment) {
          const isBlob  = msg.attachment.startsWith("blob:");
          const src     = isBlob ? msg.attachment : `/api/v1/uploads${msg.attachment}`;
          const isImage = isBlob || /\.(jpg|jpeg|png|gif|webp)$/i.test(msg.attachment);
          const fbId    = `fb-${tempId || msg._id}`;

          if (isImage) {
            mediaHTML = `
              <img class="msg-img" src="${src}" alt="img"
                   onclick="window.open('${src}')"
                   onerror="this.style.display='none';document.getElementById('${fbId}').style.display='flex'"/>
              <a id="${fbId}" href="${src}" target="_blank"
                 style="display:none;color:#63b3ed;font-size:.8rem;align-items:center;gap:.3rem;text-decoration:none;margin-bottom:4px">
                 📎 View image
              </a>`;
          } else {
            const icon = msg.attachment.endsWith(".pdf")   ? "📄"
                       : msg.attachment.includes("video")  ? "🎥"
                       : msg.attachment.includes("audio")  ? "🎵" : "📎";
            const name = msg.attachment.split("/").pop() || "attachment";
            mediaHTML  = `
              <a href="${src}" target="_blank"
                 style="color:#63b3ed;font-size:.82rem;display:flex;align-items:center;gap:.35rem;margin-bottom:4px;text-decoration:none">
                ${icon} ${esc(name)}
              </a>`;
          }
        }

        // Tick status
        let tickHTML = "";
        if (isSent) {
          let icon = "✓", cls = "st-sending";
          if (!isOptimistic) {
            if (msg.isRead)                              { icon = "✓✓"; cls = "st-read"; }
            else if (onlineIds.has(activeConv?.peerId)) { icon = "✓✓"; cls = "st-delivered"; }
          }
          const tickId = `tk-${tempId || msg._id}`;
          tickHTML     = `<span class="${cls}" id="${tickId}">${icon}</span>`;
          if (tempId) tickMap[tempId] = null;
        }

        row.innerHTML = `
          <div class="msg-bubble">
            ${mediaHTML}
            ${msg.text ? `<div>${esc(msg.text)}</div>` : ""}
            <div class="msg-footer">
              <span class="msg-time">${t}</span>
              ${tickHTML}
            </div>
          </div>`;

        wrap.insertBefore(row, typingEl);
        if (tempId) tickMap[tempId] = document.getElementById(`tk-${tempId}`);
      }

      // ═══════════════════════════════════════════════════
      // TYPING
      // ═══════════════════════════════════════════════════
      document.getElementById("msgInput").addEventListener("input", function () {
        autoResize(this);
        if (!activeConv) return;
        socket.emit("typing:start", activeConv.id);
        clearTimeout(typingTmr);
        typingTmr = setTimeout(() => socket.emit("typing:stop", activeConv.id), 1500);
      });

      // ═══════════════════════════════════════════════════
      // FILE ATTACHMENT
      // ═══════════════════════════════════════════════════
      document.getElementById("fileInput").addEventListener("change", function () {
        if (!this.files[0]) return;
        pendingFile = this.files[0];
        document.getElementById("attachName").textContent = pendingFile.name;
        document.getElementById("attachPreview").classList.add("show");
        this.value = "";
      });

      function clearAttach() {
        pendingFile = null;
        document.getElementById("attachPreview").classList.remove("show");
      }

      // ═══════════════════════════════════════════════════
      // MARK AS READ
      // ═══════════════════════════════════════════════════
      function doMarkRead(convId, senderId) {
        socket.emit("message:read", { conversationId: convId, senderId });
        fetch(`${API}/message/read/${convId}`, {
          method: "PATCH", headers: { Authorization: `Bearer ${token}` },
        }).catch(() => {});
      }

      // ═══════════════════════════════════════════════════
      // HELPERS
      // ═══════════════════════════════════════════════════
      function getPeer(participants) {
        return participants.find((p) => (p._id || p) !== me._id) || participants[0];
      }

      function refreshDots() {
        document.querySelectorAll('[id^="dot-"]').forEach((d) => {
          const uid = d.id.slice(4);
          onlineIds.has(uid) ? d.classList.add("on") : d.classList.remove("on");
        });
        if (activeConv) {
          const dot = document.getElementById("peerDot");
          if (dot) onlineIds.has(activeConv.peerId) ? dot.classList.add("on") : dot.classList.remove("on");
        }
      }

      function refreshPeerStatus() {
        if (!activeConv) return;
        onlineIds.has(activeConv.peerId)
          ? setPeerStatus("Online", true)
          : setPeerStatus("Offline", false);
      }

      function setPeerStatus(text, online) {
        const el = document.getElementById("peerStatus");
        el.textContent = text;
        el.className   = `peer-status ${online ? "online" : ""}`;
      }

      function updatePreview(convId, text, attachment, time) {
        const pv = document.getElementById(`pv-${convId}`);
        const pt = document.getElementById(`pt-${convId}`);
        if (pv) pv.textContent = text || (attachment ? "📎 Attachment" : "");
        if (pt) pt.textContent = fmtTime(time);
        const item = document.getElementById(`ci-${convId}`);
        const list = document.getElementById("convList");
        if (item && list.firstChild !== item) list.insertBefore(item, list.firstChild);
      }

      function incrBadge(convId) {
        const b = document.getElementById(`bd-${convId}`);
        if (!b) return;
        b.textContent = +b.textContent + 1; b.style.display = "block";
      }

      function hideBadge(convId) {
        const b = document.getElementById(`bd-${convId}`);
        if (b) b.style.display = "none";
      }

      function appendDateSep(d) {
        const wrap    = document.getElementById("msgsWrap");
        const typingEl= document.getElementById("typingRow");
        const el      = document.createElement("div");
        el.className  = "date-sep";
        el.innerHTML  = `<span>${d}</span>`;
        wrap.insertBefore(el, typingEl);
      }

      function fmtTime(d) {
        if (!d) return "";
        const dt  = new Date(d);
        const now = new Date();
        return dt.toDateString() === now.toDateString()
          ? dt.toLocaleTimeString([], { hour: "2-digit", minute: "2-digit" })
          : dt.toLocaleDateString([], { month: "short", day: "numeric" });
      }

      function scrollBottom() {
        const w = document.getElementById("msgsWrap");
        w.scrollTop = w.scrollHeight;
      }

      function autoResize(el) {
        el.style.height = "auto";
        el.style.height = Math.min(el.scrollHeight, 120) + "px";
      }

      function esc(s) {
        if (!s) return "";
        return String(s)
          .replace(/&/g,"&amp;").replace(/</g,"&lt;")
          .replace(/>/g,"&gt;").replace(/"/g,"&quot;").replace(/'/g,"&#39;");
      }

      function showToast(msg, ms = 3000) {
        const t = document.getElementById("toast");
        t.textContent = msg; t.classList.add("show");
        setTimeout(() => t.classList.remove("show"), ms);
      }

      async function get(url) {
        const res = await fetch(url, { headers: { Authorization: `Bearer ${token}` } });
        return res.json();
      }

      function logout() {
        socket.disconnect();
        localStorage.clear();
        location.href = "/login";
      }

      // Sidebar local search filter
      document.getElementById("searchInput").addEventListener("input", function () {
        const q = this.value.toLowerCase();
        document.querySelectorAll(".conv-item").forEach((el) => {
          el.style.display = el.querySelector(".conv-name")
            .textContent.toLowerCase().includes(q) ? "" : "none";
        });
      });
    </script>
  </body>
</html>
